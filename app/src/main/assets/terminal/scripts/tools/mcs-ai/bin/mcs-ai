#!/usr/bin/env bash

ROOT="$HOME/.mcs/tools/mcs-ai"
LOG="$ROOT/logs/repair-$(date +%F-%H%M%S).log"

# =========================
# BUILD LOG MODE (TOP)
# =========================
if [[ "$1" == "--log" ]]; then
  BUILD_LOG="$2"
  echo "[MobileCodeStudio-AI] Build failed → analysing log: $BUILD_LOG"
  echo "---------------------------------------------"

  if [ ! -f "$BUILD_LOG" ]; then
    echo "❌ Log file not found"
    exit 1
  fi

  bash "$ROOT/scanner/error-scan.sh" "$BUILD_LOG"
  bash "$ROOT/brain/explain.sh" "$BUILD_LOG"
bash "$ROOT/repair/kotlin-import-fix.sh" "$BUILD_LOG"
  exit 0
fi

# =========================
# NORMAL PROJECT MODE
# =========================

echo "[MobileCodeStudio-AI] Starting AI Repair Engine" | tee -a "$LOG"

run() {
  local f="$1"
  if [ -f "$f" ]; then
    echo "[SCAN] $(basename "$f")" | tee -a "$LOG"
    bash "$f" 2>&1 | tee -a "$LOG"
  fi
}

# === SCAN ===
run "$ROOT/scanner/gradle-check.sh"
run "$ROOT/scanner/manifest-check.sh"
run "$ROOT/scanner/sdk-check.sh"
run "$ROOT/scanner/dependency-check.sh"

# === REPAIR ===
run "$ROOT/repair/gradle-fix.sh"
run "$ROOT/repair/manifest-fix.sh"
run "$ROOT/repair/sdk-fix.sh"

echo "[MobileCodeStudio-AI] Completed" | tee -a "$LOG"
# --- Build Log Mode + Hook ---
if [[ "$1" == "--log" ]]; then
  BUILD_LOG="$2"
  echo "[MobileCodeStudio-AI] Build failed → analysing log: $BUILD_LOG"
  
  # Scan & repair
  bash "$HOME/.mcs/tools/mcs-ai/scanner/error-scan.sh" "$BUILD_LOG"
  bash "$HOME/.mcs/tools/mcs-ai/brain/explain.sh" "$BUILD_LOG"

  # Auto Kotlin imports
  bash "$ROOT/repair/kotlin-import-fix.sh" "$BUILD_LOG"

  # Run Pre-build Hook
  if [ -f "$HOME/.mcs/tools/mcs-ai/hooks/on-build-fail.sh" ]; then
    bash "$HOME/.mcs/tools/mcs-ai/hooks/on-build-fail.sh" "$BUILD_LOG"
  fi
  exit 0
fi
